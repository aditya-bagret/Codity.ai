{
  "name": "codity",
  "private": true,
  "version": "1.0.0",
  "description": "Codity — a distributed job scheduling platform",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "setup": "npm run migrate -w server && npm run seed -w server",
    "migrate": "npm run migrate -w server",
    "seed": "npm run seed -w server",
    "dev": "npm run dev -w server",
    "worker": "npm run worker -w server",
    "web": "npm run dev -w web",
    "demo": "npm run demo -w server",
    "build": "npm run build -w web",
    "typecheck": "npm run typecheck -w server && npm run typecheck -w web",
    "test": "npm test -w server",
    "test:unit": "npm run test:unit -w server"
  },
  "engines": {
    "node": ">=20"
  }
}
