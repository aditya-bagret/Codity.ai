# PostgreSQL connection string (docker-compose default shown)
DATABASE_URL=postgres://codity:codity@localhost:5433/codity

# API server
PORT=4000
JWT_SECRET=change-me-in-production

# Worker tuning
WORKER_NAME=
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=750
WORKER_HEARTBEAT_MS=5000
# Comma-separated queue names this worker subscribes to (empty = all queues)
WORKER_QUEUES=

# Scheduler / reliability
SCHEDULER_TICK_MS=1000
DEAD_WORKER_AFTER_MS=20000

